FROM node:22-alpine

WORKDIR /app

# Copy monorepo root
COPY package.json package-lock.json ./

# Copy packages
COPY packages/database/prisma ./packages/database/prisma/
COPY packages/database/package.json ./packages/database/
COPY packages/database/index.ts ./packages/database/

# Copy web app
COPY apps/web/package.json ./apps/web/

# Install deps
RUN npm install --workspace=web --include-workspace-root

# Generate Prisma Client (from database package dir)
RUN cd packages/database && npx prisma generate

# Copy app source
COPY apps/web ./apps/web/

# Ensure prisma client is available in web app's node_modules
RUN mkdir -p apps/web/node_modules/.prisma && \
    cp -r node_modules/.prisma/* apps/web/node_modules/.prisma/ 2>/dev/null || true && \
    mkdir -p apps/web/node_modules/@prisma && \
    cp -r node_modules/@prisma/* apps/web/node_modules/@prisma/ 2>/dev/null || true

WORKDIR /app/apps/web

EXPOSE 3000

CMD ["npm", "run", "dev"]
